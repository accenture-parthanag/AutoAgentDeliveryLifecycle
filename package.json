{
  "name": "agentic-adlc-platform",
  "version": "1.0.0",
  "description": "Agentic Automation Development Lifecycle Platform",
  "private": true,
  "proxy": "http://localhost:5000",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "cors": "^2.8.5",
    "docx": "^9.6.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mammoth": "^1.12.0",
    "mongodb": "^6.3.0",
    "pdf-parse": "^2.4.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "scripts": {
    "start": "react-scripts start",
    "server": "node server/index.js",
    "ba-agent": "node server/agents/ba-agent.js",
    "architect-agent": "node server/agents/architect-agent.js",
    "tech-lead-agent": "node server/agents/tech-lead-agent.js",
    "dev": "concurrently -k \"npm run server\" \"npm start\"",
    "start:all": "concurrently -k -n \"FRONTEND,BACKEND,BA,ARCH,TL\" -c \"cyan,magenta,green,yellow,blue\" \"npm start\" \"npm run server\" \"npm run ba-agent\" \"npm run architect-agent\" \"npm run tech-lead-agent\"",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
